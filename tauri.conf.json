{
    "$schema": "https://schema.tauri.app/config/2.11.0",
    "productName": "UniChat",
    "identifier": "unichat",
    "build": {
        "beforeDevCommand": "pnpm dev:ui",
        "beforeBuildCommand": "pnpm build:ui",
        "devUrl": "http://localhost:1421",
        "frontendDist": "./webapp/dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "label": "splash-screen",
                "title": "UniChat Splash Screen",
                "url": "splash-screen.html",
                "width": 500,
                "height": 300,
                "center": true,
                "focus": true,
                "resizable": false,
                "maximizable": false,
                "minimizable": false,
                "closable": false,
                "decorations": false
            }
        ],
        "security": {
            "csp": {
                "default-src": ["'self'", "asset:", "http://asset.localhost"],

                "script-src": ["'self'", "'unsafe-inline'", "asset:", "http://asset.localhost"],
                "script-src-elem": ["'self'", "'unsafe-inline'", "asset:", "http://asset.localhost"],
                "script-src-attr": ["'none'"],

                "style-src": ["'self'", "'unsafe-inline'", "asset:", "http://asset.localhost"],
                "style-src-elem": ["'self'", "'unsafe-inline'", "asset:", "http://asset.localhost"],
                "style-src-attr": ["'unsafe-inline'"],

                "img-src": ["'self'", "asset:", "blob:", "data:", "http://asset.localhost", "http://localhost:9527"],
                "media-src": ["'self'", "asset:", "blob:", "data:", "http://asset.localhost", "http://localhost:9527"],
                "connect-src": ["'self'", "ipc:", "http://ipc.localhost"],
                "frame-src": ["'self'", "http://localhost:9527"]
            }
        }
    },
    "bundle": {
        "active": true,
        "resources": ["assets/", "icons/", "plugins/", "widgets/", "LICENSE"],
        "targets": ["deb", "rpm", "appimage", "nsis", "msi", "dmg"],
        "icon": [
            "icons/32x32.png",
            "icons/64x64.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico",
            "icons/icon.png"
        ],
        "licenseFile": "./LICENSE",
        "windows": {
            "nsis": {
                "installMode": "both"
            }
        }
    }
}
